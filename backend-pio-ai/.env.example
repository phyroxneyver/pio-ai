# ============================================
# Pio AI — Backend (.env)
# ============================================
# Copia este archivo como .env y completa los valores

# ---------------------------------------------------------------------------
# Base de datos
# ---------------------------------------------------------------------------
# PostgreSQL (producción):
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/pioai_db
# SQLite (desarrollo local):
# DATABASE_URL=sqlite:////tmp/sql_app.db

# ---------------------------------------------------------------------------
# Autenticación JWT
# ---------------------------------------------------------------------------
# Clave secreta para firmar tokens (genera una con: openssl rand -hex 32)
SECRET_KEY=tu_clave_secreta_aqui
# Algoritmo de firma
ALGORITHM=HS256
# Minutos de expiración del token
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------------------------------------------------------------------------
# Almacenamiento de imágenes
# ---------------------------------------------------------------------------
# Directorio donde se guardan las imágenes subidas
UPLOAD_DIR=uploads/imagenes

#para el cloudinary

ANTHROPIC_API_KEY=sk-ant-...


